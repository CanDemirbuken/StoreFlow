@model List<Customer>
@{
    Layout = "_Layout";
    ViewBag.Title = "Müşteri Listesi";
    int count = 0;
}

<div class="row">
    <div class="col-lg-12 grid-margin stretch-card">
        <div class="card">
            <div class="card-body">
                <h3 class="card-title">Müşteri Listesi</h3>
                <p class="card-description">
                    <code>Müşteri ile ilgili işlemlerinizi buradan yapabilirsiniz.</code>
                </p>
                <div class="table-responsive">
                    <table class="table">
                        <thead>
                            <tr>
                                <th>#</th>
                                <th>Ad Soyad</th>
                                <th>Şehir</th>
                                <th>Bakiye</th>
                                <th>Sil</th>
                                <th>Güncelle</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td>@(++count)</td>
                                    <td>@item.Name @item.Surname</td>
                                    <td>@item.City / @item.District</td>
                                    <td>@item.Balance</td>
                                    <td><a href="@Url.Action("DeleteCustomer", "Customer", new { id = item.Id })" class="btn btn-outline-danger">Sil</a></td>
                                    <td><a href="@Url.Action("UpdateCustomer", "Customer", new { id = item.Id })" class="btn btn-outline-warning">Güncelle</a></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                    <a href="@Url.Action("CreateCustomer", "Customer")" class="btn btn-outline-primary">Yeni Müşteri Ekle</a>
                </div>
            </div>
        </div>
    </div>
</div>