@model List<Order>

@{
    Layout = "_Layout";
    ViewBag.Title = "Sipariş Listesi";
}

<div class="row">
    <div class="col-lg-12 grid-margin stretch-card">
        <div class="card">
            <div class="card-body">
                <h3 class="card-title">Sipariş Listesi</h3>
                <p class="card-description">
                    <code>Sipariş ile ilgili işlemlerinizi buradan yapabilirsiniz.</code>
                </p>
                <div class="table-responsive">

                    <h2>Duruma Göre Arama İşlemi</h2>
                    <form asp-action="OrderListSearch"
                          method="get"
                          class="d-flex justify-content-end align-items-center gap-2 mb-3">

                        <input type="text"
                               name="status"
                               class="form-control"
                               style="width:250px; height:50px;"
                               placeholder="Durum..." />

                        <select name="filterType"
                                class="form-control ml-2"
                                style="width:250px; height:50px;">
                            <option value="start">Başlar</option>
                            <option value="end">Biter</option>
                            <option value="contains">İçerir</option>
                        </select>

                        <button type="submit" class="btn btn-primary ml-2">
                            Filtrele
                        </button>

                    </form>

                    <table class="table">
                        <thead>
                            <tr>
                                <th>#</th>
                                <th>Ürün Adı</th>
                                <th>Müşteri</th>
                                <th>Birim Fiyat</th>
                                <th>Toplam Fiyat</th>
                                <th>Durum</th>
                                <th>Sil</th>
                                <th>Güncelle</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td>@item.Id</td>
                                    <td>@item.ProductId</td>
                                    <td>@item.CustomerId</td>
                                    <td>@item.UnitPrice</td>
                                    <td>@item.TotalPrice</td>
                                    <td>@item.Status</td>
                                    <td><a href="@Url.Action("DeleteOrder", "Order", new { id = item.Id })" class="btn btn-outline-danger">Sil</a></td>
                                    <td><a href="@Url.Action("UpdateOrder", "Order", new { id = item.Id })" class="btn btn-outline-warning">Güncelle</a></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                    <a href="@Url.Action("CreateOrder", "Order")" class="btn btn-outline-primary">Yeni Sipariş Girişi</a>
                </div>
            </div>
        </div>
    </div>
</div>