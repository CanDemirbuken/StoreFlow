@model Product

@{
    Layout = "_Layout";
    ViewBag.Title = "Ürün Ekle";
}

<div class="row">
    <div class="col-12 grid-margin stretch-card">
        <div class="card">
            <div class="card-body">
                <h4 class="card-title">Yeni Ürün Ekleme Sayfası</h4>
                <form class="forms-sample" method="post">
                    <div class="form-group">
                        <label for="exampleInputName1">Ürün Adı</label>
                        <input type="text" class="form-control" id="exampleInputName1" placeholder="Ürün Adı" asp-for="Name">
                    </div>

                    <div class="form-group">
                        <label for="exampleInputName1">Kategori</label>
                        <select asp-for="CategoryId" asp-items="@ViewBag.Categories" class="form-control">
                            <option value="">-- Kategori Seçin --</option>
                        </select>
                    </div>

                    <div class="form-group">
                        <label for="exampleInputName1">Ürün Fiyatı</label>
                        <input type="number" class="form-control" id="exampleInputName1" placeholder="Ürün Fiyatı" asp-for="Price">
                    </div>

                    <div class="form-group">
                        <label for="exampleInputName1">Ürün Stok</label>
                        <input type="number" class="form-control" id="exampleInputName1" placeholder="Ürün Stok" asp-for="Stock">
                    </div>

                    <button type="submit" class="btn btn-primary mr-2">Ekle</button>
                </form>
            </div>
        </div>
    </div>
</div>