<div class="main-panel">
    <div class="content-wrapper">
        <div class="row">
            <div class="col-md-4 grid-margin">
                <div class="card">
                    <div class="card-body">
                        <h4 class="card-title mb-0">Kategori Sayısı</h4>
                        <div class="d-flex justify-content-between align-items-center">
                            <div class="d-inline-block pt-3">
                                <div class="d-md-flex">
                                    <h2 class="mb-0">@ViewBag.categoryCount</h2>
                                </div>
                                <small class="text-gray">Toplamda @ViewBag.categoryCount kategori var.</small>
                            </div>
                            <div class="d-inline-block">
                                <i class="fas fa-chart-pie text-warning icon-lg"></i>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-4 grid-margin">
                <div class="card">
                    <div class="card-body">
                        <h4 class="card-title mb-0">En Yüksek Ürün Fiyatı</h4>
                        <div class="d-flex justify-content-between align-items-center">
                            <div class="d-inline-block pt-3">
                                <div class="d-md-flex">
                                    <h2 class="mb-0">@ViewBag.maxProductPrice TL</h2>
                                </div>
                                <small class="text-gray">En pahalı ürün <strong>@ViewBag.maxProductPriceName</strong>.</small>
                            </div>
                            <div class="d-inline-block">
                                <i class="fas fa-bell text-info icon-lg"></i>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-4 grid-margin">
                <div class="card">
                    <div class="card-body">
                        <h4 class="card-title mb-0">En Uygun Ürün Fiyatı</h4>
                        <div class="d-flex justify-content-between align-items-center">
                            <div class="d-inline-block pt-3">
                                <div class="d-md-flex">
                                    <h2 class="mb-0">@ViewBag.minProductPrice TL</h2>
                                </div>
                                <small class="text-gray">En uygun ürün <strong>@ViewBag.minProductPriceName</strong>.</small>
                            </div>
                            <div class="d-inline-block">
                                <i class="fas fa-bell text-info icon-lg"></i>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="row">
            <div class="col-md-4 grid-margin">
                <div class="card">
                    <div class="card-body">
                        <h4 class="card-title mb-0">Toplam Ürün Stok</h4>
                        <div class="d-flex justify-content-between align-items-center">
                            <div class="d-inline-block pt-3">
                                <div class="d-md-flex">
                                    <h2 class="mb-0">@ViewBag.sumProductStock</h2>
                                </div>
                                <small class="text-gray">Stokta @ViewBag.sumProductStock ürün mevcut.</small>
                            </div>
                            <div class="d-inline-block">
                                <i class="fas fa-comment text-warning icon-lg"></i>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-4 grid-margin">
                <div class="card">
                    <div class="card-body">
                        <h4 class="card-title mb-0">Ortalama Ürün Stok</h4>
                        <div class="d-flex justify-content-between align-items-center">
                            <div class="d-inline-block pt-3">
                                <div class="d-md-flex">
                                    <h2 class="mb-0">@ViewBag.averageProductStock</h2>
                                </div>
                                <small class="text-gray">Toplam Ürün Stoğu / Ürün Adet Değeri <strong>@ViewBag.averageProductStock</strong>.</small>
                            </div>
                            <div class="d-inline-block">
                                <i class="fas fa-cubes text-info icon-lg"></i>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-4 grid-margin">
                <div class="card">
                    <div class="card-body">
                        <h4 class="card-title mb-0">Ortalama Ürün Fiyatı</h4>
                        <div class="d-flex justify-content-between align-items-center">
                            <div class="d-inline-block pt-3">
                                <div class="d-md-flex">
                                    <h2 class="mb-0">@ViewBag.averageProductPrice.ToString("F2") TL</h2>
                                </div>
                                <small class="text-gray">Ortalama ürün fiyatı: <strong>@ViewBag.averageProductPrice.ToString("F2") TL</strong>.</small>
                            </div>
                            <div class="d-inline-block">
                                <i class="fas fa-desktop text-info icon-lg"></i>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="row">
            <div class="col-md-4 grid-margin">
                <div class="card">
                    <div class="card-body">
                        <h4 class="card-title mb-0">1000 TL'den Yüksek Fiyatlı Ürünler</h4>
                        <div class="d-flex justify-content-between align-items-center">
                            <div class="d-inline-block pt-3">
                                <div class="d-md-flex">
                                    <h2 class="mb-0">@ViewBag.priceGreaterThan1000Product</h2>
                                </div>
                                <small class="text-gray">Fiyatı 1000 TL'den yüksek ürün sayısı: <strong>@ViewBag.priceGreaterThan1000Product</strong>.</small>
                            </div>
                            <div class="d-inline-block">
                                <i class="fas fa-clock text-warning icon-lg"></i>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-4 grid-margin">
                <div class="card">
                    <div class="card-body">
                        <h4 class="card-title mb-0">4 Nolu ID'ye Ait Ürün Adı</h4>
                        <div class="d-flex justify-content-between align-items-center">
                            <div class="d-inline-block pt-3">
                                <div class="d-md-flex">
                                    <h2 class="mb-0">@ViewBag.getIdIs4ProductName</h2>
                                </div>
                                <small class="text-gray">ID değeri 4 olan ürün adı: <strong>@ViewBag.getIdIs4ProductName</strong>.</small>
                            </div>
                            <div class="d-inline-block">
                                <i class="fas fa-coffee text-info icon-lg"></i>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-4 grid-margin">
                <div class="card">
                    <div class="card-body">
                        <h4 class="card-title mb-0">Stok Aralığı 50-100 Olan Ürün Sayısı</h4>
                        <div class="d-flex justify-content-between align-items-center">
                            <div class="d-inline-block pt-3">
                                <div class="d-md-flex">
                                    <h2 class="mb-0">@ViewBag.stockCountGreaterThan50AndLessThan100ProductCount</h2>
                                </div>
                                <small class="text-gray">Stok miktarı 50 ile 100 arasında olan ürün sayısı: <strong>@ViewBag.stockCountGreaterThan50AndLessThan100ProductCount</strong>.</small>
                            </div>
                            <div class="d-inline-block">
                                <i class="fas fa-filter text-info icon-lg"></i>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>