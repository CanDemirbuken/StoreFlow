@model List<CategoryViewModel>

@{
    Layout = "_Layout";
    ViewBag.Title = "Kategoriler";
}

<div class="row">
    <div class="col-lg-12 grid-margin stretch-card">
        <div class="card">
            <div class="card-body">
                <h3 class="card-title">Kategori Listesi</h3>
                <p class="card-description">
                    Add class <code>Kategori ile ilgili işlemlerinizi buradan yapabilirsiniz.</code>
                </p>
                <div class="table-responsive">
                    <table class="table">
                        <thead>
                            <tr>
                                <th>#</th>
                                <th>Kategori</th>
                                <th>Durum</th>
                                <th>Sil</th>
                                <th>Güncelle</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td>@item.Id</td>
                                    <td>@item.Name</td>
                                    <td><label class="badge @item.CategoryBadgeClass badge-pill">@item.StatusText</label></td>
                                    <td><a href="@Url.Action("DeleteCategory", "Category", new { id = item.Id })" class="btn btn-outline-danger">Sil</a></td>
                                    <td><a href="@Url.Action("UpdateCategory", "Category", new { id = item.Id })" class="btn btn-outline-warning">Güncelle</a></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                    <a href="@Url.Action("CreateCategory", "Category")" class="btn btn-outline-primary">Yeni Kategori Ekle</a>
                </div>
            </div>
        </div>
    </div>
</div>