@model Category

@{
    Layout = "_Layout";
    ViewBag.Title = "Kategori Ekle";
}

<div class="row">
    <div class="col-12 grid-margin stretch-card">
        <div class="card">
            <div class="card-body">
                <h4 class="card-title">Yeni Kategori Ekleme Sayfası</h4>
                <form class="forms-sample" method="post">
                    <div class="form-group">
                        <label for="exampleInputName1">Kategori Adı</label>
                        <input type="text" class="form-control" id="exampleInputName1" placeholder="Kategori Adı" asp-for="Name">
                    </div>

                    <button type="submit" class="btn btn-primary mr-2">Ekle</button>
                </form>
            </div>
        </div>
    </div>
</div>